          "description": "Dot product similarity"
        }
      ]
    },
    {
      "name": "terra.nova.observability.logging.level",
      "values": [
        {
          "value": "TRACE",
          "description": "Trace level logging"
        },
        {
          "value": "DEBUG",
          "description": "Debug level logging"
        },
        {
          "value": "INFO",
          "description": "Info level logging"
        },
        {
          "value": "WARN",
          "description": "Warning level logging"
        },
        {
          "value": "ERROR",
          "description": "Error level logging"
        }
      ]
    }
  ]
}
