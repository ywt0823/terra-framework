{
  "groups": [
    {
      "name": "terra.nova",
      "type": "com.terra.framework.nova.properties.TerraNovaProperties",
      "description": "Terra-Nova LLM Pipeline and Prompt Engineering Framework configuration properties."
    },
    {
      "name": "terra.nova.spring-ai",
      "type": "com.terra.framework.nova.properties.TerraNovaProperties$SpringAI",
      "description": "Spring AI integration configuration."
    },
    {
      "name": "terra.nova.models",
      "type": "com.terra.framework.nova.properties.TerraNovaProperties$Models",
      "description": "Model configuration for different AI providers."
    },
    {
      "name": "terra.nova.enhancement",
      "type": "com.terra.framework.nova.properties.TerraNovaProperties$Enhancement",
      "description": "Enhancement features configuration including cache, retry, and monitoring."
    },
    {
      "name": "terra.nova.rag",
      "type": "com.terra.framework.nova.properties.TerraNovaProperties$Rag",
      "description": "Retrieval Augmented Generation (RAG) configuration."
    },
    {
      "name": "terra.nova.blending",
      "type": "com.terra.framework.nova.properties.TerraNovaProperties$Blending",
      "description": "Model blending and ensemble configuration."
    },
    {
      "name": "terra.nova.vector-stores",
      "type": "com.terra.framework.nova.properties.TerraNovaProperties$VectorStores",
      "description": "Vector database configuration for different providers."
    },
    {
      "name": "terra.nova.observability",
      "type": "com.terra.framework.nova.properties.TerraNovaProperties$Observability",
      "description": "Observability configuration including metrics, tracing, and logging."
    }
  ],
  "properties": [
    {
      "name": "terra.nova.enabled",
      "type": "java.lang.Boolean",
      "description": "Whether to enable Terra-Nova framework.",
      "defaultValue": true
    },
    {
      "name": "terra.nova.spring-ai.enabled",
      "type": "java.lang.Boolean",
      "description": "Whether to enable Spring AI integration.",
      "defaultValue": true
    },
    {
      "name": "terra.nova.spring-ai.auto-register-models",
      "type": "java.lang.Boolean",
      "description": "Whether to automatically register Spring AI models.",
      "defaultValue": true
    },
    {
      "name": "terra.nova.models.default-provider",
      "type": "java.lang.String",
      "description": "Default AI model provider to use.",
      "defaultValue": "openai"
    },
    {
      "name": "terra.nova.enhancement.cache.enabled",
      "type": "java.lang.Boolean",
      "description": "Whether to enable intelligent caching.",
      "defaultValue": true
    },
    {
      "name": "terra.nova.enhancement.cache.ttl",
      "type": "java.time.Duration",
      "description": "Cache time-to-live duration.",
      "defaultValue": "1h"
    },
    {
      "name": "terra.nova.enhancement.cache.similarity-threshold",
      "type": "java.lang.Double",
      "description": "Similarity threshold for semantic caching (0.0-1.0).",
      "defaultValue": 0.95
    },
    {
      "name": "terra.nova.enhancement.retry.enabled",
      "type": "java.lang.Boolean",
      "description": "Whether to enable retry mechanism.",
      "defaultValue": true
    },
    {
      "name": "terra.nova.enhancement.retry.max-attempts",
      "type": "java.lang.Integer",
      "description": "Maximum number of retry attempts.",
      "defaultValue": 3
    },
    {
      "name": "terra.nova.enhancement.retry.backoff.initial-interval",
      "type": "java.time.Duration",
      "description": "Initial retry interval.",
      "defaultValue": "1s"
    },
    {
      "name": "terra.nova.enhancement.retry.backoff.multiplier",
      "type": "java.lang.Double",
      "description": "Backoff multiplier for exponential retry.",
      "defaultValue": 2.0
    },
    {
      "name": "terra.nova.enhancement.retry.backoff.max-interval",
      "type": "java.time.Duration",
      "description": "Maximum retry interval.",
      "defaultValue": "10s"
    },
    {
      "name": "terra.nova.enhancement.monitoring.enabled",
      "type": "java.lang.Boolean",
      "description": "Whether to enable monitoring and metrics.",
      "defaultValue": true
    },
    {
      "name": "terra.nova.enhancement.monitoring.metrics-enabled",
      "type": "java.lang.Boolean",
      "description": "Whether to enable metrics collection.",
      "defaultValue": true
    },
    {
      "name": "terra.nova.enhancement.monitoring.tracing-enabled",
      "type": "java.lang.Boolean",
      "description": "Whether to enable distributed tracing.",
      "defaultValue": true
    },
    {
      "name": "terra.nova.rag.enabled",
      "type": "java.lang.Boolean",
      "description": "Whether to enable RAG (Retrieval Augmented Generation) functionality.",
      "defaultValue": false
    },
    {
      "name": "terra.nova.rag.vector-store.type",
      "type": "java.lang.String",
      "description": "Type of vector store to use (redis, postgresql, etc.).",
      "defaultValue": "redis"
    },
    {
      "name": "terra.nova.rag.vector-store.similarity-threshold",
      "type": "java.lang.Double",
      "description": "Similarity threshold for vector search (0.0-1.0).",
      "defaultValue": 0.8
    },
    {
      "name": "terra.nova.rag.vector-store.top-k",
      "type": "java.lang.Integer",
      "description": "Number of top similar documents to retrieve.",
      "defaultValue": 5
    },
    {
      "name": "terra.nova.rag.document.chunk-size",
      "type": "java.lang.Integer",
      "description": "Size of document chunks for processing.",
      "defaultValue": 1000
    },
    {
      "name": "terra.nova.rag.document.chunk-overlap",
      "type": "java.lang.Integer",
      "description": "Overlap size between document chunks.",
      "defaultValue": 200
    },
    {
      "name": "terra.nova.blending.enabled",
      "type": "java.lang.Boolean",
      "description": "Whether to enable model blending and ensemble functionality.",
      "defaultValue": false
    },
    {
      "name": "terra.nova.vector-stores.redis.host",
      "type": "java.lang.String",
      "description": "Redis host for vector storage.",
      "defaultValue": "localhost"
    },
    {
      "name": "terra.nova.vector-stores.redis.port",
      "type": "java.lang.Integer",
      "description": "Redis port for vector storage.",
      "defaultValue": 6379
    },
    {
      "name": "terra.nova.vector-stores.redis.index-name",
      "type": "java.lang.String",
      "description": "Redis index name for vector storage.",
      "defaultValue": "terra-vectors"
    },
    {
      "name": "terra.nova.vector-stores.redis.distance-metric",
      "type": "java.lang.String",
      "description": "Distance metric for vector similarity (COSINE, EUCLIDEAN, DOT_PRODUCT).",
      "defaultValue": "COSINE"
    },
    {
      "name": "terra.nova.vector-stores.postgresql.url",
      "type": "java.lang.String",
      "description": "PostgreSQL connection URL for vector storage.",
      "defaultValue": "jdbc:postgresql://localhost:5432/vectordb"
    },
    {
      "name": "terra.nova.vector-stores.postgresql.table-name",
      "type": "java.lang.String",
      "description": "PostgreSQL table name for vector storage.",
      "defaultValue": "vector_store"
    },
    {
      "name": "terra.nova.vector-stores.postgresql.dimensions",
      "type": "java.lang.Integer",
      "description": "Vector dimensions for PostgreSQL storage.",
      "defaultValue": 1536
    },
    {
      "name": "terra.nova.observability.metrics.enabled",
      "type": "java.lang.Boolean",
      "description": "Whether to enable metrics collection.",
      "defaultValue": true
    },
    {
      "name": "terra.nova.observability.metrics.export.prometheus",
      "type": "java.lang.Boolean",
      "description": "Whether to export metrics to Prometheus.",
      "defaultValue": true
    },
    {
      "name": "terra.nova.observability.metrics.export.cloudwatch",
      "type": "java.lang.Boolean",
      "description": "Whether to export metrics to CloudWatch.",
      "defaultValue": false
    },
    {
      "name": "terra.nova.observability.tracing.enabled",
      "type": "java.lang.Boolean",
      "description": "Whether to enable distributed tracing.",
      "defaultValue": true
    },
    {
      "name": "terra.nova.observability.tracing.sampling-rate",
      "type": "java.lang.Double",
      "description": "Tracing sampling rate (0.0-1.0).",
      "defaultValue": 0.1
    },
    {
      "name": "terra.nova.observability.logging.level",
      "type": "java.lang.String",
      "description": "Logging level for Terra-Nova components.",
      "defaultValue": "INFO"
    },
    {
      "name": "terra.nova.observability.logging.include-request-response",
      "type": "java.lang.Boolean",
      "description": "Whether to include request/response in logs.",
      "defaultValue": false
    }
  ],
  "hints": [
